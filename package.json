{
  "name": "wasteremoval",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --host",
    "generate": "nuxt generate",
    "postgenerate": "node scripts/harden-static-fallbacks.mjs",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "optimize-images": "node scripts/optimize-images.mjs",
    "generate-favicons": "node scripts/generate-favicons.mjs",
    "audit:seo": "node scripts/audit-generated-seo.mjs",
    "verify:admin-rules": "node scripts/verify-admin-firestore-rules.mjs",
    "verify:seo": "npm run generate && npm run audit:seo",
    "validate-business-details": "node scripts/validate-business-details.mjs",
    "fetch-image": "node --env-file=.env scripts/fetch-pexels-image.mjs",
    "deploy": "npm run validate-business-details && npm run verify:seo && npx -y firebase-tools@latest deploy --only hosting,functions,firestore",
    "firebase:version": "npx -y firebase-tools@latest --version",
    "firebase:login": "npx -y firebase-tools@latest login --no-localhost",
    "firebase:use": "npx -y firebase-tools@latest use wasteremoval-3276",
    "firebase:functions:list": "npx -y firebase-tools@latest functions:list --project wasteremoval-3276",
    "firebase:firestore:list": "npx -y firebase-tools@latest firestore:databases:list --project wasteremoval-3276",
    "firebase:firestore:create": "npx -y firebase-tools@latest firestore:databases:create \"(default)\" --location us-central1 --project wasteremoval-3276",
    "firebase:extensions:list": "npx -y firebase-tools@latest ext:list --project wasteremoval-3276",
    "firebase:email-secret:check": "npx -y firebase-tools@latest functions:secrets:get firestore-send-email-SMTP_PASSWORD --project wasteremoval-3276",
    "firebase:email-secret": "npx -y firebase-tools@latest functions:secrets:set firestore-send-email-SMTP_PASSWORD --project wasteremoval-3276",
    "firebase:deploy:email": "npx -y firebase-tools@latest deploy --only functions,firestore,hosting,extensions --project wasteremoval-3276",
    "firebase:deploy:extensions": "npx -y firebase-tools@latest deploy --only extensions --project wasteremoval-3276"
  },
  "dependencies": {
    "@nuxtjs/robots": "^5.0.0",
    "@nuxtjs/sitemap": "^7.0.0",
    "firebase": "^12.14.0",
    "nuxt": "^4.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vue-tsc": "^2.1.0"
  }
}
