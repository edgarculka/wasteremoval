# Trigger Email from Firestore: firebase/firestore-send-email
# The createBooking Cloud Function writes email documents into this collection.
MAIL_COLLECTION=mail

# Gmail Workspace SMTP. Store the password/app password in Secret Manager; do not commit it.
# Create it with:
# npx -y firebase-tools@latest functions:secrets:set firestore-send-email-SMTP_PASSWORD --project wasteremoval-3276
SMTP_CONNECTION_URI=smtps://contact%40dbs-waste.co.uk@smtp.gmail.com:465
SMTP_PASSWORD=projects/${param:PROJECT_NUMBER}/secrets/firestore-send-email-SMTP_PASSWORD/versions/latest

DEFAULT_FROM=contact@dbs-waste.co.uk
DEFAULT_REPLY_TO=contact@dbs-waste.co.uk

# Not used by the booking flow, but configured so the extension has stable paths if templates/users are added later.
TEMPLATES_COLLECTION=email_templates
USERS_COLLECTION=users

# Keep extension delivery docs for troubleshooting, then allow TTL cleanup.
TTL_EXPIRE_TYPE=month
TTL_EXPIRE_VALUE=1

# Keep the extension close to the website function region.
firebaseextensions.v1beta.function/location=europe-west2
