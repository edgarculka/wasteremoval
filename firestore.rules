rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bookings
    // Document ID: booking reference generated by the createBooking
    // Cloud Function, e.g. 8 uppercase letters/numbers.
    //
    // Server-created quote fields include customer PII (name, email, phone,
    // addressLine1, postcode), collection details (date, time, load,
    // additionalItems, photos), estimated totals, createdAt, source, and
    // submissionId. The browser admin UI is the authority for the admin
    // workflow, so any signed-in Firebase Auth user can read, update, and
    // delete booking documents without Firestore field-level restrictions.
    // Public booking creates remain allowed because the quote form has a direct
    // Firestore fallback when the HTTPS booking function is unavailable.
    //
    // Collection: mail
    // Documents are written by trusted server code and the
    // firestore-send-email extension only. Browser clients have no access.
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    match /bookings/{bookingId} {
      allow read, update, delete: if isAuthenticated();
      allow create: if true;
    }

    match /mail/{mailId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
